            if (result.success) {
                const topics = result.data.topics;
                let content = `✅ Educational Topics Retrieved Successfully\n\n`;
                content += `📖 Total Topics: ${topics.length}\n\n`;
                
                // Group topics by module
                const topicsByModule = {};
                topics.forEach(topic => {
                    if (!topicsByModule[topic.module_name]) {
                        topicsByModule[topic.module_name] = [];
                    }
                    topicsByModule[topic.module_name].push(topic);
                });
                
                Object.keys(topicsByModule).forEach(moduleName => {
                    content += `📚 ${moduleName}:\n`;
                    topicsByModule[moduleName].slice(0, 3).forEach((topic, index) => {
                        content += `   ${index + 1}. ${topic.title}\n`;
                        content += `      🎯 ${topic.difficulty_level}\n`;
                    });
                    if (topicsByModule[moduleName].length > 3) {
                        content += `   ... and ${topicsByModule[moduleName].length - 3} more topics\n`;
                    }
                    content += '\n';
                });
                
                showResult('content-result', content, 'success');
            } else {
                showResult('content-result', `❌ Failed to fetch topics\n\nError: ${JSON.stringify(result.data, null, 2)}`, 'error');
            }
        }
        
