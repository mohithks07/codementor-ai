        async function runComprehensiveTest() {
            showResult('comprehensive-result', '🚀 Initializing comprehensive system validation...', 'pending');
            
            const tests = [
                { name: 'Backend Connectivity', fn: testConnectivity, weight: 20 },
                { name: 'User Registration', fn: testRegister, weight: 15 },
                { name: 'Modules Retrieval', fn: testModules, weight: 15 },
                { name: 'Topics Retrieval', fn: testTopics, weight: 15 },
                { name: 'Quiz System', fn: testQuiz, weight: 20 },
                { name: 'AI Chat System', fn: testAIResponse, weight: 15 }
            ];
            
            let results = [];
            let passed = 0;
            let failed = 0;
            let totalWeight = 0;
            let earnedWeight = 0;
            
            for (const test of tests) {
                try {
                    showResult('comprehensive-result', `Testing ${test.name}...`, 'pending');
                    await test.fn();
                    passed++;
                    earnedWeight += test.weight;
                    results.push(`✅ ${test.name}: PASSED (${test.weight}%)`);
                } catch (error) {
                    failed++;
                    results.push(`❌ ${test.name}: FAILED - ${error.message}`);
                }
                totalWeight += test.weight;
                await new Promise(resolve => setTimeout(resolve, 800));
            }
            
            const overallScore = Math.round((earnedWeight / totalWeight) * 100);
            const status = overallScore >= 90 ? 'success' : overallScore >= 70 ? 'warning' : 'error';
            
            let report = `🧪 Comprehensive System Test Results\n\n`;
            report += `📊 Overall Score: ${overallScore}%\n`;
            report += `✅ Passed: ${passed}/${tests.length} tests\n`;
            report += `❌ Failed: ${failed}/${tests.length} tests\n\n`;
            
            report += `📋 Detailed Results:\n${results.join('\n')}\n\n`;
            
            report += `🎯 System Assessment:\n`;
            if (overallScore >= 90) {
                report += `🏆 EXCELLENT! System is production-ready\n`;
                report += `✅ All critical components operational\n`;
                report += `🚀 Ready for deployment`;
            } else if (overallScore >= 70) {
                report += `👍 GOOD! System mostly functional\n`;
                report += `⚠️ Minor issues need attention\n`;
                report += `🔧 Review failed components`;
            } else {
                report += `⚠️ NEEDS ATTENTION\n`;
                report += `🔧 Significant issues found\n`;
                report += `🚫 Not ready for production`;
            }
            
            report += `\n🎉 CodeMentor AI Platform Status: ${overallScore >= 90 ? 'DEPLOYMENT READY' : 'NEEDS REFINEMENT'}`;
            
            showResult('comprehensive-result', report, status);
        }
        
